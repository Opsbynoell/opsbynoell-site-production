# ---------------------------------------------------------
# Ops by Noell — agent backend environment variables
# ---------------------------------------------------------
# Copy to .env.local for local dev. Set all required vars in
# Vercel project settings for production.

# Supabase (project clipzfkbzupjctherijz)
SUPABASE_URL=https://clipzfkbzupjctherijz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic / Claude
ANTHROPIC_API_KEY=
# Optional: override the model. Default: claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Telegram operator alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# Twilio (generic SMS provider — only required if any client uses smsProvider=twilio or generic)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# GoHighLevel (only required if any client uses calendarProvider=ghl or smsProvider=ghl)
# A per-location API key can override this via clients.calendar_config.apiKey.
GHL_API_KEY=
# GHL_API_BASE=https://services.leadconnectorhq.com
# GHL_API_VERSION=2021-07-28

# Vercel cron shared secret (any HTTP caller hitting /api/cron/* without
# the `x-vercel-cron` header must send Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Two-way SMS reply bridge — webhook secret used by BOTH GHL inbound routes:
#   - POST /api/ghl/inbound-sms           (owner replies to alert SMS)
#   - POST /api/ghl/inbound-visitor-sms   (leads/customers texting the LC Phone)
# Generate with: openssl rand -hex 32
# Paste the same value as the ?secret= query param in each LC workflow webhook URL.
GHL_WEBHOOK_SECRET=

# Meta Pixel (client-side analytics for Facebook / Instagram ads)
# Pixel lives in the "Nikki Noell" business portfolio.
# Leave blank in dev to disable pixel firing locally.
NEXT_PUBLIC_META_PIXEL_ID=792219100378130
